{
  "_comment": "テストスイートの例。FMEngineTest に渡すと全エントリを順番に実行する。",
  "test_suite": [
    {
      "_comment": "エントリ1: YMEngine で OPNA + OPM をリアルタイム再生",
      "engine":      "YMEngine.dll",
      "sample_rate": 48000,
      "patches":     ["patches/opna.json", "patches/opm.json"]
    },
    {
      "_comment": "エントリ2: NukedEngine で OPL2 + OPL3 を WAV エクスポート",
      "engine":      "NukedEngine.dll",
      "sample_rate": 44100,
      "output_wav":  "out/nuked_opl_44100.wav",
      "patches":     ["patches/opl2.json", "patches/opl3.json"]
    },
    {
      "_comment": "エントリ3: YMEngine で OPNA を WAV エクスポート (48000Hz)",
      "engine":      "YMEngine.dll",
      "sample_rate": 48000,
      "output_wav":  "out/ymengine_opna_48000.wav",
      "patches":     ["patches/opna.json"]
    },
    {
      "_comment": "エントリ4: デバイス指定あり。engine/sample_rate は省略 → CLI -e / -r の値を使用",
      "device":  "Realtek",
      "patches": ["patches/opna.json"]
    },
    {
      "_comment": "エントリ5: 全フィールド省略 → CLI オプションをそのまま使用してリアルタイム再生",
      "patches": ["patches/all.json"]
    }
  ]
}
